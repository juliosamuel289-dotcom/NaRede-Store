# Copie este arquivo para .env e preencha com seus valores reais
# No Render: adicione cada variável em Environment > Add Environment Variable
# Não faça commit do arquivo .env com valores reais

# ── Banco de dados Aiven (MySQL) ─────────────────────────
# Encontre estas credenciais em: Aiven Console > seu serviço > Connection information
DB_HOST=mysql-xxxxxxxx.aivencloud.com
DB_PORT=16604
DB_USER=avnadmin
DB_PASSWORD=sua-senha-do-aiven
DB_NAME=defaultdb

# ── Gmail (App Password) ──────────────────────────────────
# Gere em: Conta Google > Segurança > Senhas de app
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Ambiente ──────────────────────────────────────────────
# Em produção no Render, defina como: production
# Em desenvolvimento local, defina como: development
NODE_ENV=development
