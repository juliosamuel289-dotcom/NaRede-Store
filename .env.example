# Copie este arquivo para .env e preencha com seus valores reais
# No Render: adicione cada variável em Environment > Add Environment Variable
# Não faça commit do arquivo .env com valores reais

# ── Firebase Admin SDK ───────────────────────────────────
# Encontre em: Firebase Console > Configurações do projeto > Contas de serviço > Gerar nova chave privada
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Firebase Web API Key ──────────────────────────────────
# Encontre em: Firebase Console > Configurações do projeto > Geral > Chave de API da Web
FIREBASE_WEB_API_KEY=AIzaSy...

# ── Brevo (e-mail transacional) ───────────────────────────
# Encontre em: Brevo > SMTP & API > Chaves de API
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=seu-email@dominio.com

# ── MercadoPago ───────────────────────────────────────────
# Encontre em: MercadoPago Developers > Suas integrações > Credenciais
MP_ACCESS_TOKEN=APP_USR-...

# ── URL do site (para redirecionamento após pagamento) ────
SITE_URL=https://naredestore-api.onrender.com
